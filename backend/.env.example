# Copy to backend/.env and fill in. Never commit the real .env.
# Supabase -> Settings -> API keys
#
# CRITICAL: SUPABASE_SERVICE_ROLE_KEY must be the SECRET key (sb_secret_...), NOT
# the publishable one. The member-data tables have RLS on and admit only
# service_role; a publishable key here loses all access to them and every write
# (profile, labs, entitlements, vendor submissions, session metering) fails. The
# backend logs a loud error at startup if this key is not a secret key.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...            # server-side ONLY, never ship to frontend
# Used as the apikey header when validating a member's access token against
# Supabase Auth. This is the PUBLISHABLE key (sb_publishable_...), public by
# design — the same key the browser holds.
SUPABASE_ANON_KEY=sb_publishable_...

# ---- Payments (Stripe) ----------------------------------------------------
# From dashboard.stripe.com -> Developers -> API keys. Use sk_test_ to rehearse,
# sk_live_ to take real money. Without this the app runs but cannot sell.
STRIPE_SECRET_KEY=
# From the Stripe webhook endpoint you create for POST /billing/webhook. Optional
# for a first sale (the return-from-checkout path grants without it), required to
# handle refunds and disputes.
STRIPE_WEBHOOK_SECRET=
STACK_REPORT_PRICE_CENTS=100
STACK_REPORT_ACCESS_DAYS=30

# ---- Access control -------------------------------------------------------
# Browser origins allowed to call this API, comma-separated. REQUIRED in any
# deploy: the default is localhost only, so a deploy without this will refuse
# the real frontend. `*` is rejected at startup.
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Emails allowed to read operator surfaces (the intake queue at /consult/intakes).
# Comma-separated. Empty means nobody, which is the safe default.
ADMIN_EMAILS=

# ---- Tavus CVI spend limits ----------------------------------------------
# Tavus bills wall-clock replica minutes, has NO overage limit, and exposes no
# usage or credits API. These bounds are the only thing preventing a runaway
# bill, so none of them may be left unset in a real deploy.
#
# Per-conversation ceiling. Left to the Tavus default this is 3600s, and
# participant_left_timeout has no documented default at all — a member who
# closes the tab can leave the replica running. At the current overage rate a
# single abandoned session is worth more than twenty dollars.
TAVUS_MAX_CALL_SECONDS=300
TAVUS_LEFT_TIMEOUT_SECONDS=45
TAVUS_ABSENT_TIMEOUT_SECONDS=90
# Account-wide monthly ceiling, enforced by us in consult_sessions. Set it to
# the minutes you have actually paid for.
TAVUS_MONTHLY_MINUTE_BUDGET=100
TAVUS_MAX_CONCURRENT=2
TAVUS_SESSIONS_PER_USER=3

# Model providers
BASETEN_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Junction (Vital) — patient data import (wearable + bloodwork). Server-side only.
# Sandbox key from the Junction dashboard (prefix sk_us_*).
JUNCTION_API_KEY=
JUNCTION_BASE_URL=https://api.sandbox.tryvital.io
JUNCTION_REGION=us
JUNCTION_ENV=sandbox
JUNCTION_DEMO_ORDER_ID=   # optional: pin a sandbox lab order for the bloodwork demo
