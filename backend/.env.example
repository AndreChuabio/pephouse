# Copy to backend/.env and fill in. Never commit the real .env.
# Supabase -> Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side ONLY, never ship to frontend

# Model providers
BASETEN_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Junction (Vital) — patient data import (wearable + bloodwork). Server-side only.
# Sandbox key from the Junction dashboard (prefix sk_us_*).
JUNCTION_API_KEY=
JUNCTION_BASE_URL=https://api.sandbox.tryvital.io
JUNCTION_REGION=us
JUNCTION_ENV=sandbox
JUNCTION_DEMO_ORDER_ID=   # optional: pin a sandbox lab order for the bloodwork demo
